# ==============================================
# PDF Service — Environment Configuration
# ==============================================
# Copy file ini menjadi .env
# cp .env.example .env

# ----------------------------------------------
# PORT
# ----------------------------------------------
# Port yang di-expose ke host
EXPOSE_PORT=7100

# ----------------------------------------------
# DOCKER SOCKET
# ----------------------------------------------
# Sesuaikan dengan environment kamu:
# Linux / VPS standard:
DOCKER_SOCK=/var/run/docker.sock
# Mac Docker Desktop:
# DOCKER_SOCK=/Users/youruser/.docker/run/docker.sock
# Mac Orbstack:
# DOCKER_SOCK=/var/run/docker.sock.raw

# ----------------------------------------------
# GOTENBERG AUTH
# ----------------------------------------------
# Credentials untuk basic auth di Gotenberg (bukan Traefik)
GOTENBERG_USER=admin
GOTENBERG_PASS=ganti_dengan_password_kuat
